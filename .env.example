# --- Database ---
# Local dev: SQLite file (no setup needed)
# DATABASE_URL="file:./dev.db"
#
# Production on Vercel: use Vercel Postgres or Neon.
# 1) Vercel dashboard -> Storage -> Create Database -> Postgres (Neon)
# 2) Copy the "DATABASE_URL" it gives you into your Vercel Project's
#    Environment Variables, and also paste it below for local testing.
# 3) In prisma/schema.prisma change provider = "sqlite" to provider = "postgresql"
DATABASE_URL="file:./dev.db"

# --- Admin login ---
# Username for the single admin account
ADMIN_USERNAME="admin"
# Bcrypt hash of the admin password. Generate one with:
#   node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 10))"
ADMIN_PASSWORD_HASH="$2a$10$replace_with_generated_hash"

# --- Session ---
# Any long random string, used to sign admin session cookies
SESSION_SECRET="replace_with_a_long_random_string"
