generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Category {
  NHAN
  VONG_LAC
  DAY_CHUYEN
  QUA_TANG
  QUA_LUU_NIEM
  KHAC
}

enum Material {
  VANG_24K
  VANG_18K
  VANG_14K
  BAC_925
  DA_QUY
  HOP_KIM
}

enum QuoteStatus {
  MOI
  DANG_XU_LY
  DA_BAO_GIA
  HOAN_TAT
  HUY
}

enum OrderStatus {
  DAT_COC
  DANG_SAN_XUAT
  KIEM_TRA
  SAN_SANG_GIAO
  DA_GIAO
  HOAN_TAT
  HUY
}

enum TransactionType {
  THU
  CHI
}

enum TransactionCategory {
  THU_KHACH_HANG
  CHI_XUONG
  CHI_NGUYEN_LIEU
  CHI_VAN_HANH
  KHAC
}

model Customer {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  type        String   @default("")
  contactName String   @default("")
  phone       String   @default("")
  email       String   @default("")
  address     String   @default("")
  taxCode     String   @default("")
  notes       String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders       Order[]
  transactions Transaction[]
}

model Workshop {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  contactName String   @default("")
  phone       String   @default("")
  address     String   @default("")
  specialty   String   @default("")
  notes       String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders       Order[]
  transactions Transaction[]
}

model Product {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  slug           String   @unique
  category       Category
  material       Material
  description    String
  imageUrl       String
  minQuantity    Int      @default(1)
  isCustomizable Boolean  @default(true)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  quoteItems QuoteItem[]
  orderItems OrderItem[]
}

model QuoteRequest {
  id               String      @id @default(cuid())
  companyName      String
  contactName      String
  phone            String
  email            String
  organizationType String      @default("")
  message          String      @default("")
  status           QuoteStatus @default(MOI)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  items  QuoteItem[]
  orders Order[]
}

model QuoteItem {
  id             String       @id @default(cuid())
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  quoteRequestId String
  product        Product      @relation(fields: [productId], references: [id])
  productId      String
  quantity       Int          @default(1)
  note           String       @default("")
}

model Order {
  id               String        @id @default(cuid())
  code             String        @unique
  customer         Customer      @relation(fields: [customerId], references: [id])
  customerId       String
  quoteRequest     QuoteRequest? @relation(fields: [quoteRequestId], references: [id])
  quoteRequestId   String?
  workshop         Workshop?     @relation(fields: [workshopId], references: [id])
  workshopId       String?
  status           OrderStatus   @default(DAT_COC)
  depositAmount    Float         @default(0)
  totalAmount      Float         @default(0)
  expectedDelivery DateTime?
  deliveredAt      DateTime?
  assignedTo       String        @default("")
  internalNote     String        @default("")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  items        OrderItem[]
  transactions Transaction[]
}

model OrderItem {
  id         String   @id @default(cuid())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    String
  product    Product? @relation(fields: [productId], references: [id])
  productId  String?
  customName String   @default("")
  quantity   Int      @default(1)
  unitPrice  Float    @default(0)
  note       String   @default("")
}

model Transaction {
  id          String              @id @default(cuid())
  code        String              @unique
  type        TransactionType
  category    TransactionCategory
  amount      Float
  date        DateTime
  description String              @default("")
  orderId     String?
  customerId  String?
  workshopId  String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  order    Order?    @relation(fields: [orderId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  workshop Workshop? @relation(fields: [workshopId], references: [id])
}
